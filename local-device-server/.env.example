PORT=4040
SERVER_TOKEN=change-me-to-a-long-random-secret-32-chars-min
# The Netlify domain(s) that are allowed to make requests to this server.
# Separate multiple origins with a comma.
ALLOWED_ORIGINS=https://your-crm.netlify.app,https://your-second-crm.netlify.app
# Absolute path where uploaded files will be stored.
# Defaults to ~/CRM-Files if not set.
FILES_DIR=/Users/yourname/CRM-Files
