{
  "name": "crm-client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "concurrently --names \"vite,fns\" --prefix-colors \"cyan,yellow\" \"vite\" \"tsx local-functions-server.ts\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "storage:status": "powershell -Command \"Get-Service MinIOCRM | Select-Object Name,Status,StartType | Format-Table -AutoSize\"",
    "storage:start": "powershell -Command \"Start-Service MinIOCRM; Write-Host 'MinIO started. Console: http://localhost:9001'\"",
    "storage:stop": "powershell -Command \"Stop-Service MinIOCRM; Write-Host 'MinIO stopped.'\""
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.15.0",
    "@aws-sdk/client-s3": "^3.978.0",
    "@aws-sdk/s3-request-presigner": "^3.982.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.4",
    "@netlify/functions": "^5.1.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.9",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "nodemailer": "^7.0.13",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.9.3",
    "tailwindcss": "^4.1.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "tsx": "^4.19.2",
    "concurrently": "^9.1.2"
  }
}
