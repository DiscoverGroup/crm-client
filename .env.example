# Gmail SMTP Configuration for Password Reset Emails
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
FROM_EMAIL=your_gmail_address@gmail.com
FROM_NAME=DG-CRM

# MongoDB Atlas Configuration
MONGODB_URI=your_mongodb_atlas_connection_string

# Cloudflare Turnstile (bot protection on login form)
# Get keys from: https://dash.cloudflare.com → Turnstile → Add widget
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key      # public — safe for frontend
TURNSTILE_SECRET_KEY=your_turnstile_secret_key        # private — Netlify env only, never in frontend

# Daily Backup (Netlify scheduled function → Cloudflare R2)
# BACKUP_SECRET is no longer needed — manual trigger uses admin JWT auth instead.
# Scheduled (nightly) backup runs automatically — no env var required for that either.
